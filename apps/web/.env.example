# ─── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Setup checklist ───────────────────────────────────────────────────────────
# 1. Create a Supabase project at https://supabase.com
# 2. Enable Phone auth (Twilio SMS) or Email OTP in Auth → Providers
# 3. Create a PRIVATE storage bucket named exactly: resumes
#    (Storage → New bucket → Name: resumes → Public: OFF)
# 4. Run migrations in order via SQL editor or: supabase db push
# 5. Copy this file to .env.local and fill in real values
